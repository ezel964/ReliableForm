# ReliableForm configuration — copied to .env by setup.sh
# Real environment variables override these values (launch.sh relies on that).

APP_ENV=dev
APP_URL=http://localhost:8080

# Ports
LB_PORT=8080
WEB1_PORT=9001
WEB2_PORT=9002
STATUS_PORT=9301

# Backing-service runtime: podman|auto|host. Docker is forbidden — the
# stateful tier (MySQL, Redis, gearmand) runs in Podman via
# config/podman/compose.yaml. podman (default) requires Podman + podman-compose;
# offers a host fallback if unavailable. auto soft-falls back to host-installed
# services with a warning. host forces system-installed MySQL/Redis/gearmand.
INFRA_RUNTIME=podman

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=reliableform
DB_USER=reliableform
DB_PASS=reliableform
# Container image tags (podman mode only) — pinned + overridable.
# (The MySQL container's root password is randomized by compose; the app never
# uses root, only DB_USER/DB_PASS above.)
MYSQL_IMAGE=docker.io/library/mysql:8.4
REDIS_IMAGE=docker.io/library/redis:7-alpine

# Redis (cache, rate limits, heartbeats — and sessions/queues when the
# drivers below say so)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Web tier runtime: auto|fpm|cli. auto uses php-fpm pools when the binary is
# found (production parity: opcache, pm saturation, /fpm-status), else php -S.
WEB_RUNTIME=auto
# Session storage: mysql (sessions table, production parity) or redis.
SESSION_DRIVER=mysql
# Queue driver: auto|gearman|redis. auto is resolved once by launch.sh
# (gearmand binary present => gearman, else redis) and exported to every
# service it starts, so web and workers can never disagree mid-run.
QUEUE_DRIVER=auto
GEARMAN_HOST=127.0.0.1
GEARMAN_PORT=4730

# statsd metrics sink (fire-and-forget UDP; safe to leave unset/unused)
STATSD_HOST=127.0.0.1
STATSD_PORT=8125

# OpenTelemetry traces (OTLP/HTTP JSON). Leave unset to disable exporting
# entirely. Point at a collector to receive one span per request/job, e.g.:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=          # optional service.name override

# Structured JSON app log (storage/logs/app-<instance>.jsonl); 0 disables.
APPLOG_ENABLED=1
# Public form submissions per minute per (form, client IP); 0 disables.
RATE_LIMIT_SUBMIT_PER_MIN=30

# Frontend SRE (browser telemetry beacons).
# Fraction of web-vitals beacons to keep at POST /v1/rum (1.0 = all, 0 = none).
RUM_SAMPLE_RATE=1.0
# JS error reporting at POST /v1/clientlog; 0 disables ingestion.
CLIENTLOG_ENABLED=1
# Per-IP clientlog beacons per minute; 0 disables the limit (fails open).
CLIENTLOG_RATE_PER_MIN=120

SESSION_TTL=86400
