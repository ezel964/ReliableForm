# ReliableForm configuration — copied to .env by setup.sh
# Real environment variables override these values (launch.sh relies on that).

APP_ENV=dev
APP_URL=http://localhost:8080

# Ports
LB_PORT=8080
WEB1_PORT=9001
WEB2_PORT=9002
STATUS_PORT=9301

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=reliableform
DB_USER=reliableform
DB_PASS=reliableform

# Redis (sessions, cache, queues, heartbeats)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# statsd metrics sink (fire-and-forget UDP; safe to leave unset/unused)
STATSD_HOST=127.0.0.1
STATSD_PORT=8125

# OpenTelemetry traces (OTLP/HTTP JSON). Leave unset to disable exporting
# entirely. Point at a collector to receive one span per request/job, e.g.:
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_SERVICE_NAME=          # optional service.name override

# Structured JSON app log (storage/logs/app-<instance>.jsonl); 0 disables.
APPLOG_ENABLED=1
# Public form submissions per minute per (form, client IP); 0 disables.
RATE_LIMIT_SUBMIT_PER_MIN=30

SESSION_TTL=86400
